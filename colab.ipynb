   "source": [
    "---\n",
    "### \U0001f680 Bước 1: Khởi chạy ứng dụng\n",
    "\n",
    "Chạy cell bên dưới \u0111ể khởi \u0111ộng **Gradio app** với public share link."
   ],
   "id": "ea8332e9"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "LAUNCH_APP"
   },
   "outputs": [],
   "source": [
    "# === CELL 2: Chạy Gradio app với share link ===\n",
    "import sys, threading\n",
    "sys.path.insert(0, \"hf\")\n",
    "\n",
    "print(\"\U0001f680 \u0110ang kh\u1edfi \u0111\u1ed9ng libracal...\")\n",
    "\n",
    "from app import demo\n",
    "\n",
    "def run():\n",
    "    demo.launch(share=True, server_name=\"0.0.0.0\", server_port=7860)\n",
    "\n",
    "t = threading.Thread(target=run, daemon=True)\n",
    "t.start()\n",
    "\n",
    "import time, urllib.request, json\n",
    "time.sleep(3)\n",
    "try:\n",
    "    with urllib.request.urlopen(\"http://localhost:7860\") as resp:\n",
    "        pass\n",
    "except Exception:\n",
    "    time.sleep(5)\n",
    "\n",
    "print(\"\u2705 Gradio app \u0111ã ch\u1ea1y!\")\n",
    "print(\"\U0001f310 Mở link Gradio bên dưới (dòng 'Running on public URL:')\")"
   ],
   "id": "c4abd7cf"
